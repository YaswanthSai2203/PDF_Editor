// =============================================================================
// PDF Editor SaaS — Database Schema
// Datasource: PostgreSQL (swap url for Supabase / Railway / Neon)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// AUTH & IDENTITY
// =============================================================================

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts           Account[]
  sessions           Session[]
  memberships        TeamMember[]
  documents          Document[]
  annotations        Annotation[]
  annotationReplies  AnnotationReply[]
  signatures         SignatureRequest[] @relation("Requester")
  signatureSlots     SignatureSlot[]
  subscription       Subscription?
  auditLogs          AuditLog[]
  apiKeys            ApiKey[]
  formSubmissions    FormSubmission[]

  @@index([email])
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================================
// TEAMS & ORGANIZATIONS
// =============================================================================

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  plan        PlanTier @default(FREE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     TeamMember[]
  documents   Document[]
  subscription Subscription?
  invitations TeamInvitation[]
  apiKeys     ApiKey[]

  @@index([slug])
}

model TeamMember {
  id        String     @id @default(cuid())
  teamId    String
  userId    String
  role      TeamRole   @default(MEMBER)
  joinedAt  DateTime   @default(now())

  team      Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model TeamInvitation {
  id        String           @id @default(cuid())
  teamId    String
  email     String
  role      TeamRole         @default(MEMBER)
  token     String           @unique @default(cuid())
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime         @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([email])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

// =============================================================================
// DOCUMENTS
// =============================================================================

model Document {
  id          String         @id @default(cuid())
  title       String
  description String?
  ownerId     String
  teamId      String?
  storageKey  String         // S3/R2 object key for original PDF
  fileSize    Int            // bytes
  pageCount   Int            @default(0)
  status      DocumentStatus @default(PROCESSING)
  isShared    Boolean        @default(false)
  shareToken  String?        @unique
  password    String?        // bcrypt hash if password protected
  thumbnailKey String?       // S3 key for first-page thumbnail
  ocrStatus   OcrStatus      @default(NONE)
  ocrText     String?        @db.Text
  metadata    Json           @default("{}")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  owner       User           @relation(fields: [ownerId], references: [id])
  team        Team?          @relation(fields: [teamId], references: [id])
  versions    DocumentVersion[]
  annotations Annotation[]
  signatureRequests SignatureRequest[]
  formDefinition FormDefinition?
  formSubmissions  FormSubmission[]
  collaborators    DocumentCollaborator[]
  auditLogs        AuditLog[]

  @@index([ownerId])
  @@index([teamId])
  @@index([shareToken])
  @@index([deletedAt])
}

enum DocumentStatus {
  PROCESSING
  READY
  ERROR
}

enum OcrStatus {
  NONE
  PENDING
  PROCESSING
  DONE
  ERROR
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  version     Int
  storageKey  String
  fileSize    Int
  changeNote  String?
  createdById String?
  createdAt   DateTime @default(now())

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@index([documentId])
}

model DocumentCollaborator {
  id         String           @id @default(cuid())
  documentId String
  email      String
  permission CollabPermission @default(COMMENT)
  addedAt    DateTime         @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, email])
  @@index([documentId])
}

enum CollabPermission {
  VIEW
  COMMENT
  EDIT
  ADMIN
}

// =============================================================================
// ANNOTATIONS
// =============================================================================

model Annotation {
  id         String         @id @default(cuid())
  documentId String
  userId     String
  page       Int
  type       AnnotationType
  data       Json           // Serialized annotation data (coords, color, text, etc.)
  isResolved Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])
  replies  AnnotationReply[]

  @@index([documentId])
  @@index([userId])
  @@index([documentId, page])
}

enum AnnotationType {
  HIGHLIGHT
  UNDERLINE
  STRIKETHROUGH
  RECTANGLE
  ELLIPSE
  LINE
  ARROW
  FREEHAND
  TEXT
  COMMENT
  STAMP
  IMAGE
  LINK
}

model AnnotationReply {
  id           String   @id @default(cuid())
  annotationId String
  userId       String
  content      String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  annotation Annotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@index([annotationId])
  @@index([userId])
}

// =============================================================================
// SIGNATURES
// =============================================================================

model SignatureRequest {
  id          String                @id @default(cuid())
  documentId  String
  requesterId String
  title       String
  message     String?               @db.Text
  status      SignatureRequestStatus @default(PENDING)
  dueDate     DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  completedAt DateTime?

  document  Document       @relation(fields: [documentId], references: [id])
  requester User           @relation("Requester", fields: [requesterId], references: [id])
  slots     SignatureSlot[]

  @@index([documentId])
  @@index([requesterId])
}

enum SignatureRequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
}

model SignatureSlot {
  id                String      @id @default(cuid())
  signatureRequestId String
  signerId          String?     // null = external signer (email only)
  signerEmail       String
  signerName        String?
  accessToken       String      @unique @default(cuid())
  page              Int
  x                 Float
  y                 Float
  width             Float
  height            Float
  order             Int         @default(0)
  status            SlotStatus  @default(PENDING)
  signatureData     String?     @db.Text // base64 PNG or SVG
  signatureType     SignatureType?
  signedAt          DateTime?
  ipAddress         String?
  userAgent         String?

  signatureRequest  SignatureRequest @relation(fields: [signatureRequestId], references: [id], onDelete: Cascade)
  signer            User?           @relation(fields: [signerId], references: [id])

  @@index([signatureRequestId])
  @@index([signerId])
  @@index([accessToken])
}

enum SlotStatus {
  PENDING
  VIEWED
  SIGNED
  DECLINED
}

enum SignatureType {
  DRAWN
  TYPED
  UPLOADED
  CERTIFICATE
}

// =============================================================================
// FORMS
// =============================================================================

model FormDefinition {
  id         String    @id @default(cuid())
  documentId String    @unique
  fields     Json      // Array of FormField definitions
  settings   Json      @default("{}")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  document    Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  submissions FormSubmission[]

  @@index([documentId])
}

model FormSubmission {
  id               String   @id @default(cuid())
  formDefinitionId String
  documentId       String
  submitterId      String?
  submitterEmail   String?
  data             Json     // { fieldId: value }
  submittedAt      DateTime @default(now())
  ipAddress        String?

  formDefinition FormDefinition @relation(fields: [formDefinitionId], references: [id], onDelete: Cascade)
  document       Document       @relation(fields: [documentId], references: [id])
  submitter      User?          @relation(fields: [submitterId], references: [id])

  @@index([formDefinitionId])
  @@index([documentId])
}

// =============================================================================
// BILLING & SUBSCRIPTIONS
// =============================================================================

enum PlanTier {
  FREE
  PRO
  ENTERPRISE
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String?            @unique
  teamId               String?            @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 PlanTier           @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  seats                Int                @default(1)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User? @relation(fields: [userId], references: [id])
  team Team? @relation(fields: [teamId], references: [id])

  @@index([stripeCustomerId])
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
  INCOMPLETE
}

// =============================================================================
// API KEYS & AUDIT
// =============================================================================

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique  // SHA-256 hash of the actual key
  keyPrefix   String              // First 8 chars for display (e.g. "pdfed_ab")
  userId      String?
  teamId      String?
  scopes      String[]  @default([])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([userId])
  @@index([teamId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  documentId String?
  action     String   // e.g. "document.view", "annotation.create", "signature.signed"
  metadata   Json     @default("{}")
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user     User?     @relation(fields: [userId], references: [id])
  document Document? @relation(fields: [documentId], references: [id])

  @@index([userId])
  @@index([documentId])
  @@index([createdAt])
  @@index([action])
}
